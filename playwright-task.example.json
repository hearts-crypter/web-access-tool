{
  "schemaVersion": 1,
  "name": "example-homepage-read",
  "url": "https://example.com",
  "browser": "chromium",
  "headless": true,
  "timeoutMs": 30000,
  "retries": 1,
  "retryDelayMs": 500,
  "allowSideEffects": false,
  "allowPrivateNetwork": false,
  "outputDir": "scripts/playwright-output",
  "output": { "format": "json" },
  "actions": [
    { "type": "waitFor", "selector": { "role": "heading", "name": "Example Domain" } },
    { "type": "extract", "selector": "h1", "mode": "text", "as": "pageTitle" },
    { "type": "extract", "selector": "p", "mode": "allText", "as": "paragraphs" },
    { "type": "screenshot", "path": "scripts/playwright-output/step-1-example.png", "fullPage": true }
  ]
}
